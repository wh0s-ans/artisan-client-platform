# Backend
DATABASE_URL=postgresql+psycopg://artisan_user:artisan_password@postgres:5432/artisan_platform
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here

# CORS
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:5173"]

# Frontend
VITE_API_URL=http://localhost:8000

# AWS (optionnel, pour déploiement)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id
ECR_REGISTRY=your-account-id.dkr.ecr.us-east-1.amazonaws.com

